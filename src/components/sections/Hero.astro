---
import { siteConfig, socialLinks } from '../../data/site';
import type { Lang } from '../../i18n';
import { getLocale } from '../../i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const t = getLocale(lang);
---

<section
  id="hero"
  class="hero-section relative flex min-h-screen items-center justify-center overflow-hidden"
>
  <div class="relative mx-auto max-w-3xl px-6 py-32 text-center">
    {
      siteConfig.availableForWork && (
        <span class="available-badge">
          <span class="available-dot" />
          {t.hero.availableBadge}
        </span>
      )
    }

    <h1 class="mt-6 text-5xl font-extrabold tracking-tight sm:text-6xl lg:text-7xl">
      {t.hero.greeting}{' '}
      <span class="text-accent">{siteConfig.name}</span>
    </h1>

    <p class="mt-4 text-lg font-medium tracking-wide text-muted">{siteConfig.role}</p>

    <p class="mx-auto mt-6 max-w-xl text-lg leading-8 text-muted">
      {siteConfig.tagline}
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <a href="#projects" class="btn btn-primary btn-lg">{t.hero.cta.work}</a>
      <a href="#contact" class="btn btn-secondary btn-lg">{t.hero.cta.contact}</a>
    </div>

    <ul class="mt-10 flex items-center justify-center gap-6">
      {
        socialLinks.map((link) => (
          <li>
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              class="social-link"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <a
    href="#about"
    aria-label="Scroll down"
    class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-muted opacity-60 hover:opacity-100 transition-opacity"
  >
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="animate-bounce">
      <path
        d="M8 3v10M3 9l5 5 5-5"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>
</section>
